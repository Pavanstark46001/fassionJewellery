# Copy this file to .env in the same directory as docker-compose.yml and fill
# in real values before running `docker compose up --build`.

# PostgreSQL (existing remote instance — see jewellery-backend/README notes;
# this stack does not run its own Postgres container)
DB_USERNAME=jewellery_app
DB_PASSWORD=change-me
DB_URL=jdbc:postgresql://192.168.100.142:5432/jewellery_store

# JWT signing secret — must be at least 32 characters, unique per environment
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Public URLs once deployed (used for CORS, sitemap.xml, robots.txt)
FRONTEND_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Baked into the frontend build — must point at wherever the backend is
# actually reachable from the end user's browser
VITE_API_BASE_URL=http://localhost:8090/api/v1
